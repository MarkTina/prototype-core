{
  "name": "@marktowin/prototype-core",
  "version": "1.2.9",
  "description": "面向移动端与 PC Web 原型的 Vue 评审、流程和协作内核",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts/sync-page-descriptions.mjs",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "prototype-core-sync-page-descriptions": "scripts/sync-page-descriptions.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarkTina/prototype-core.git"
  },
  "scripts": {
    "dev": "pnpm --dir examples/basic dev",
    "check:architecture": "node scripts/check-architecture.mjs",
    "test": "node --experimental-strip-types --test tests/collaborationPolicy.test.ts tests/versionUpdate.test.ts tests/testCases.test.ts",
    "build:core": "vite build",
    "build:example": "pnpm --dir examples/basic build",
    "build": "pnpm check:architecture && pnpm test && pnpm build:core && pnpm build:example",
    "pack:check": "pnpm pack --pack-destination .packages",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@lucide/vue": "^1.16.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@lucide/vue": "^1.16.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "dependencies": {
    "exceljs": "4.4.0"
  }
}
